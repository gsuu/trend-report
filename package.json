{
  "name": "cttd-trend-magazine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "fetch:dev": "node scripts/tracking/fetch_dev_news.mjs",
    "fetch:tracking": "node scripts/tracking/fetch_tracking_news.mjs",
    "collect:materials": "node scripts/tracking/collect_materials.mjs",
    "collect:raw": "node scripts/legacy/tracking_to_collection.mjs",
    "tracking:prepare": "node scripts/tracking/collect_materials.mjs",
    "tracking:brief": "node scripts/tracking/collect_materials.mjs --no-fetch",
    "notion:upload": "python scripts/notion/push_notion.py",
    "magazine:export-json": "python scripts/notion/export_magazine_json.py",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@notionhq/client": "^4.0.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "nodemailer": "^8.0.6",
    "rss-parser": "^3.13.0",
    "vite": "^7.2.7",
    "vue": "^3.5.25"
  }
}
